# ============================================================
# QueryMind AI — Environment Variables
# ============================================================
# Copy this file to .env and fill in your real values.
# NEVER commit .env to git — it contains secrets.
#
# cp .env.example .env
# ============================================================

# ----------------------------------------------------------
# LiveKit — Voice Infrastructure
# ----------------------------------------------------------
# Get these from: https://cloud.livekit.io
# Create a new project → Settings → Keys
LIVEKIT_URL=wss://your-project.livekit.cloud
LIVEKIT_API_KEY=your_livekit_api_key
LIVEKIT_API_SECRET=your_livekit_api_secret

# ----------------------------------------------------------
# Deepgram — Streaming Speech-to-Text
# ----------------------------------------------------------
# Get from: https://console.deepgram.com
# Create account → API Keys → Create Key
DEEPGRAM_API_KEY=your_deepgram_api_key

# ----------------------------------------------------------
# Groq — LLM API (Llama 3.3 70B)
# ----------------------------------------------------------
# Get from: https://console.groq.com
# Create account → API Keys → Create new key
GROQ_API_KEY=your_groq_api_key

# ----------------------------------------------------------
# ElevenLabs — Streaming Text-to-Speech
# ----------------------------------------------------------
# Get from: https://elevenlabs.io → Profile → API Keys
# Voice ID: go to Voices → pick a voice → copy its ID
# Default voice used if ELEVENLABS_VOICE_ID is left blank: Rachel
ELEVENLABS_API_KEY=your_elevenlabs_api_key
ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM

# ----------------------------------------------------------
# Twilio — PSTN Phone Number + SIP Bridge
# ----------------------------------------------------------
# Get from: https://console.twilio.com
# Account SID + Auth Token are on the dashboard home page
# Phone Number: buy/use a number from Twilio console
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=+1xxxxxxxxxx

# ----------------------------------------------------------
# Airtable — Call Log Database
# ----------------------------------------------------------
# PAT (Personal Access Token): https://airtable.com → Account → Developer Hub → Personal Access Tokens
# Base ID: open your base → Help → API Docs → Base ID starts with "app"
# Table name must match exactly what you created in Airtable
AIRTABLE_PAT=your_airtable_personal_access_token
AIRTABLE_BASE_ID=appXXXXXXXXXXXXXX
AIRTABLE_TABLE_NAME=call_logs

# ----------------------------------------------------------
# Call Safety — Max Duration in Seconds
# ----------------------------------------------------------
# Calls longer than this are gracefully ended to prevent
# runaway API costs. Default: 300 seconds (5 minutes)
MAX_CALL_DURATION_SECONDS=300
